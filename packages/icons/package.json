{
  "name": "@aliimam/icons",
  "version": "1.1.2",
  "description": "Custom React icon library generated from JSON",
  "license": "MIT",
  "source": "./src/index.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "generate:icons": "tsx scripts/generate-icons.ts",
    "build": "tsup",
    "prepublishOnly": "npm run generate:icons && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
