{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "button-04",
  "title": "Button Demo",
  "description": "Example showing a simple button.",
  "registryDependencies": [
    "button"
  ],
  "files": [
    {
      "path": "examples/button/button-04.tsx",
      "content": "import { Mail } from \"@aliimam/icons\"\nimport {\n  Apple,\n  Bluesky,\n  Facebook,\n  Github, \n  Instagram,\n  LinkedIn,\n  Threads, \n  Vercel, \n  WhatsApp,\n  X,\n} from \"@aliimam/logos\"\n\nimport { Button } from \"@/components/ui/button\"\n\nexport default function ButtonDemo() {\n  return (\n    <div className=\"flex max-w-lg flex-wrap gap-3\">\n      <Button className=\"w-full\">Login</Button>\n      <Button variant={\"outline\"} className=\"w-full\">\n        Create account\n      </Button>\n      <div className=\"grid w-full grid-cols-3 gap-3\">\n        <Button className=\"w-full\" variant=\"outline\" size=\"icon\">\n          <Facebook/>\n        </Button>\n        <Button className=\"w-full\" variant=\"outline\" size=\"icon\">\n          <Github />\n        </Button>\n        <Button className=\"w-full\" variant=\"outline\" size=\"icon\">\n          <Facebook />\n        </Button>\n      </div>\n      <Button size=\"icon-lg\">\n        <Instagram />\n      </Button>\n      <Button size=\"icon-lg\">\n        <X />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <LinkedIn />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <Vercel />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <Github />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <Facebook />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <Bluesky />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <WhatsApp />\n      </Button>\n      <Button variant=\"outline\" size=\"icon-lg\">\n        <Threads />\n      </Button>\n      <Button variant=\"outline\">\n        <Facebook />\n        Login with Facebook\n      </Button>\n      <Button variant=\"outline\">\n        <Github />\n        Signup with Github\n      </Button>\n      <Button>\n        <X />\n        Continue with X\n      </Button>\n      <Button variant={\"secondary\"}>\n        <Mail/>\n        Login with email\n      </Button>\n      <Button variant={\"outline\"}>\n        <Apple/>\n        Login with Apple\n      </Button>\n      <div className=\"flex items-center gap-2\">\n        Dont have an account?\n        <Button className=\"px-0\" variant={\"link\"}>\n          Sign up\n        </Button>\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}