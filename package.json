{
  "name": "aliimam",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Ali Imam",
    "url": "https://x.com/aliimam_in"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:registry": "pnpm --filter=www build:registry && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "registry:build": "pnpm --filter=www registry:build && pnpm lint:fix && pnpm format:write -- --loglevel silent",
    "build:icons": "turbo run build --filter=@aliimam/icons...",
    "build:logos": "turbo run build --filter=@aliimam/logos...",
    "clean:all": "pnpm -r exec rm -rf node_modules && rm -rf node_modules .turbo pnpm-lock.yaml",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format:write": "turbo run format:write",
    "format:check": "turbo run format:check",
    "check": "turbo lint typecheck format:check",
    "release": "changeset version",
    "test:dev": "turbo run test --force",
    "test": "start-server-and-test dev http://localhost:4000 test:dev",
    "validate:registries": "pnpm validate:registries"
  },
  "packageManager": "pnpm@9.0.6",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "@manypkg/cli": "^0.20.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "13.3.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-turbo": "^1.13.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-tailwindcss": "3.13.1",
    "motion": "^12.38.0",
    "postcss": "^8.5.14",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.3.1",
    "puppeteer": "^23.11.1",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.1",
    "turbo": "^2.9.14",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.9"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.9.3"
  }
}
